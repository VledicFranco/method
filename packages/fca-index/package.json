  "author": "Francisco Aramburo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VledicFranco/method.git",
    "directory": "packages/fca-index"
  },
  "homepage": "https://github.com/VledicFranco/method#readme",
  "bugs": {
    "url": "https://github.com/VledicFranco/method/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testkit": {
      "types": "./dist/testkit/index.d.ts",
      "default": "./dist/testkit/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "default": "./dist/mcp/server.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "fca-index": "./dist/cli/index.js",
    "fca-index-mcp": "./dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "better-sqlite3": "^12.0.0",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "optionalDependencies": {
    "@lancedb/lancedb": "^0.8.0"
  },
