{
  "name": "@method/bridge",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"['dashboard.html','live-output.html','transcript.html','manifest.json','icon-192.svg','icon-512.svg'].forEach(f=>require('fs').copyFileSync('src/'+f,'dist/'+f))\"",
    "build:viz": "cd viz && npm install && npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --import tsx --test src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@method/core": "*",
    "node-pty": "^1.0.0",
    "fastify": "^5.0.0",
    "js-yaml": "^4.1.1",
    "p-queue": "^8.0.0",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsx": "^4.19.2"
  }
}
