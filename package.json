{
  "name": "method",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build --workspace=packages/bridge --if-present",
    "test": "npx tsx --test \"packages/bridge/src/domains/**/*.test.ts\" \"packages/bridge/src/shared/**/*.test.ts\"",
    "test:coverage": "c8 --reporter=text --reporter=html npx tsx --test \"packages/bridge/src/domains/**/*.test.ts\" \"packages/bridge/src/shared/**/*.test.ts\"",
    "bridge": "npm run build && npm run build --workspace=packages/bridge && node scripts/start-bridge.js",
    "bridge:dev": "npm run build && npm run build --workspace=packages/bridge && node scripts/start-bridge.js",
    "bridge:stop": "node scripts/kill-port.js",
    "bridge:cleanup": "node scripts/cleanup-claude.js"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
