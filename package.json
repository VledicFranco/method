{
  "name": "method",
  "version": "0.1.0",
  "description": "MCP server that enforces research and cognitive methodologies at runtime via sampling",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "node --input-type=module -e \"import{rmSync}from'node:fs';rmSync('dist',{recursive:true,force:true})\"",
    "start": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "methodology",
    "sampling",
    "llm",
    "enforcement",
    "research-team",
    "goal-directed-loop"
  ],
  "author": "Vledic | Franco",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
