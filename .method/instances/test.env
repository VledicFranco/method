# Test instance profile
# Isolated bridge for integration testing — separate port, fixture data, no genesis.

# Instance identifier
INSTANCE_NAME=test

# Separate port to avoid conflicts with production bridge
PORT=3457

# Root directory for project discovery — uses test fixtures instead of real repos
ROOT_DIR=test-fixtures/bridge-test

# Event log written to temp location to avoid polluting production logs
EVENT_LOG_PATH=/tmp/method-test-events.jsonl

# Disable multi-agent orchestration during testing
GENESIS_ENABLED=false

# Limit concurrent sessions for test stability
MAX_SESSIONS=3
